        stage('Commit Changes') {
            steps {
                script {
                        echo "Committing changes to the repository..."
                            sh """
                               ENCODED_EMAIL=$(echo "$GITHUB_EMAIL_CREDENTIAL" | jq -sRr @uri)
                               git config user.name "rodyb"
                               git config user.email "$GITHUB_EMAIL_CREDENTIAL"

                               git checkout main || git checkout -b main origin/main

                               git pull origin main --rebase || echo "Nothing to pull."

                               echo "bla" > bla.txt
                               git add bla.txt
                               git commit -m "Add bla.txt with initial content" || echo "Nothing to commit."

                               git push https://$ENCODED_EMAIL:$GITHUB_PASSWORD_CREDENTIAL@github.com/Rodyb/devops-projects.git main
                            """
                }
            }
        }
